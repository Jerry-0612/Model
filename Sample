    # df = pd.read_csv('your_customer_data.csv')
    # texts = df['your_text_column'].tolist()
    
    # ==================== 初始化分析器 ====================
    analyzer = TextClusterAnalyzer(
        model_path=LOCAL_MODEL_PATH,          # 使用本地模型
        model_name='all-MiniLM-L6-v2',        # 备用在线模型
        min_cluster_size=3,                   # 最小聚类大小（根据数据量调整）
        min_samples=2,                        # 核心点邻域中的最小样本数
        cluster_selection_epsilon=0.5,        # 聚类选择的距离阈值
        use_gpu=False,                        # 是否使用GPU
        random_state=42
    )
    
    # ==================== 执行聚类分析 ====================
    
    # 1. 生成嵌入向量
    embeddings = analyzer.generate_embeddings(sample_texts)
    
    # 2. （可选）降维以提高聚类效果
    # 如果文本量很大，可以考虑降维；如果文本量较小（<1000），可以跳过
    if len(sample_texts) > 500:
        embeddings_reduced = analyzer.reduce_dimensionality(embeddings, variance_ratio=0.95)
    else:
        embeddings_reduced = embeddings
        # 仍然进行标准化
        analyzer.scaler.fit(embeddings)
        print(f"跳过降维，使用原始嵌入向量: {embeddings.shape}")
    
    # 3. 执行HDBSCAN聚类
    cluster_labels = analyzer.perform_clustering(embeddings_reduced)
    
    # 4. 分析结果
    analyzer.analyze_clusters(sample_texts, cluster_labels, top_n=3)
    
    # 5. 可视化（可选）
    try:
        # 使用PCA降维到2D进行可视化
        pca_2d = PCA(n_components=2, random_state=42)
        vis_embeddings = pca_2d.fit_transform(embeddings_reduced)
        analyzer.visualize_clusters(vis_embeddings, cluster_labels, method='pca')
    except Exception as e:
        print(f"无法显示可视化: {e}")
    
    # 6. 保存结果
    analyzer.save_results(sample_texts, cluster_labels, 'customer_text_clusters.csv')
    
    # ==================== 高级功能：对新文本进行预测 ====================
    print("\n" + "="*60)
    print("对新文本进行聚类预测示例")
    print("="*60)
    
    new_texts = [
        "产品很棒，服务也很好",
        "物流很慢，包装破损"
    ]
    
    # 生成新文本的嵌入向量
    new_embeddings = analyzer.generate_embeddings(new_texts)
    
    # 如果之前做了降维，需要对新的嵌入向量也进行相同的转换
    if embeddings_reduced.shape[1] != embeddings.shape[1]:
        new_embeddings_scaled = analyzer.scaler.transform(new_embeddings)
        new_embeddings_reduced = analyzer.pca.transform(new_embeddings_scaled)
        new_labels = hdbscan.approximate_predict(analyzer.clusterer, new_embeddings_reduced)[0]
    else:
        new_embeddings_scaled = analyzer.scaler.transform(new_embeddings)
        new_labels = hdbscan.approximate_predict(analyzer.clusterer, new_embeddings_scaled)[0]
    
    for text, label in zip(new_texts, new_labels):
        label_str = f"聚类 {label}" if label != -1 else "噪声点/新类别"
        print(f"文本: {text}")
        print(f"预测标签: {label_str}\n")

